[user]
	name = troi
	email = blametroi@gmail.com
[core]
	packedGitLimit=512m
	packedGitWindowSize=512m
	pager = delta
[pack]
	deltaCacheSize=2047m
	packSizeLimit=2047m
	windowMemory=2047m
[init]
	defaultBranch = main
[merge]
	tool = mvimdiff
	conflictStyle = zdiff3
[diff]
	tool = mvimdiff
[difftool]
	prompt = false
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
